# Anthropic API key for Claude (primary LLM). If unset, server runs in stub mode.
ANTHROPIC_API_KEY=

# Claude model to use. Keep deterministic (temperature set in code).
ANTHROPIC_MODEL=claude-sonnet-4-6

# Tavily API key for optional research enrichment. If unset, enrichment is skipped.
TAVILY_API_KEY=

# Server bind
HOST=0.0.0.0
PORT=8000

# LLM sampling (PRD: <= 0.4 for determinism)
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4000

# Max retries when the LLM returns invalid JSON
LLM_MAX_JSON_RETRIES=3

# Langfuse tracing. Leave both keys blank to disable tracing entirely.
# Accepts either LANGFUSE_BASE_URL or LANGFUSE_HOST; if both are set, HOST wins.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=http://localhost:3000
